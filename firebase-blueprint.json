{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User's fitness profile and goals",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "currentWeight": { "type": "number" },
        "height": { "type": "number" },
        "weightGoal": { "type": "number" },
        "dumbbellWeight": { "type": "number" },
        "fitnessLevel": { "type": "string", "enum": ["principiante", "intermedio", "avanzado"] },
        "motivation": { "type": "string", "enum": ["perder_peso", "ganar_musculo", "salud_general", "otro"] },
        "startDate": { "type": "string", "format": "date-time" },
        "planDay": { "type": "integer" }
      },
      "required": ["uid", "currentWeight", "height", "dumbbellWeight", "fitnessLevel", "motivation", "startDate"]
    },
    "WeightLog": {
      "title": "Weight Log",
      "description": "Daily weight tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "weight": { "type": "number" }
      },
      "required": ["uid", "date", "weight"]
    },
    "WorkoutLog": {
      "title": "Workout Log",
      "description": "Daily workout completion",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "day": { "type": "integer" },
        "date": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "duration": { "type": "integer" }
      },
      "required": ["uid", "day", "date", "completed"]
    },
    "DailyWorkout": {
      "title": "Daily Workout",
      "description": "Cached workout generated by AI",
      "type": "object",
      "properties": {
        "day": { "type": "integer" },
        "title": { "type": "string" },
        "exercises": { "type": "array" }
      },
      "required": ["day", "title", "exercises"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/workouts/{dayId}": {
      "schema": "DailyWorkout",
      "description": "Cached daily workout"
    },
    "/users/{userId}/weightLogs/{logId}": {
      "schema": "WeightLog",
      "description": "User's weight history"
    },
    "/users/{userId}/workoutLogs/{logId}": {
      "schema": "WorkoutLog",
      "description": "User's workout history"
    }
  }
}
