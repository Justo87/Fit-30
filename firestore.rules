// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - name: string (optional)
//   - email: string (optional)
//   - currentWeight: number (required)
//   - height: number (required)
//   - weightGoal: number (optional)
//   - dumbbellWeight: number (required)
//   - fitnessLevel: string (required, enum)
//   - motivation: string (required, enum)
//   - startDate: string (required, ISO 8601)
//   - planDay: number (optional)
//
// Collection: users/{userId}/weightLogs
// Document ID: {logId}
// Fields:
//   - uid: string (required)
//   - date: string (required, ISO 8601)
//   - weight: number (required)
//
// Collection: users/{userId}/workoutLogs
// Document ID: {logId}
// Fields:
//   - uid: string (required)
//   - day: number (required)
//   - date: string (required, ISO 8601)
//   - completed: boolean (required)
//   - duration: number (required)
//
// Collection: users/{userId}/challengeLogs
// Document ID: {logId}
// Fields:
//   - uid: string (required)
//   - day: number (required)
//   - date: string (required, ISO 8601)
//   - completed: boolean (required)
//   - title: string (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'currentWeight', 'height', 'dumbbellWeight', 'fitnessLevel', 'motivation', 'startDate']) &&
             data.uid is string &&
             data.currentWeight is number &&
             data.height is number &&
             data.dumbbellWeight is number &&
             data.fitnessLevel in ['principiante', 'intermedio', 'avanzado'] &&
             data.motivation in ['perder_peso', 'ganar_musculo', 'salud_general', 'otro'] &&
             data.startDate is string;
    }
    
    function isValidWeightLog(data) {
      return data.keys().hasAll(['uid', 'date', 'weight']) &&
             data.uid is string &&
             data.date is string &&
             data.weight is number;
    }
    
    function isValidWorkoutLog(data) {
      return data.keys().hasAll(['uid', 'day', 'date', 'completed', 'duration']) &&
             data.uid is string &&
             data.day is number &&
             data.date is string &&
             data.completed is bool &&
             data.duration is number;
    }

    function isValidChallengeLog(data) {
      return data.keys().hasAll(['uid', 'day', 'date', 'completed', 'title']) &&
             data.uid is string &&
             data.day is number &&
             data.date is string &&
             data.completed is bool &&
             data.title is string;
    }

    function isValidWorkout(data) {
      return data.keys().hasAll(['day', 'title', 'exercises']) &&
             data.day is number &&
             data.title is string &&
             data.exercises is list;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /workouts/{dayId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidWorkout(request.resource.data);
      }

    match /weightLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWeightLog(request.resource.data);
        allow update: if isOwner(userId) && isValidWeightLog(request.resource.data);
        allow delete: if isOwner(userId);
      }
      
      match /workoutLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWorkoutLog(request.resource.data);
        allow update: if isOwner(userId) && isValidWorkoutLog(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /challengeLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChallengeLog(request.resource.data);
        allow update: if isOwner(userId) && isValidChallengeLog(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
